# Local development overrides for Firebase Emulators
# This file takes precedence over .env in development

# Firebase Emulator Configuration
REACT_APP_FIREBASE_DATABASE_URL=http://localhost:9001?ns=buttonsflowerfarm-8a54d-default-rtdb
REACT_APP_FIREBASE_AUTH_EMULATOR_URL=http://localhost:9099
REACT_APP_FIREBASE_FUNCTIONS_URL=http://localhost:5001
REACT_APP_USE_EMULATOR=true

# Development settings
NODE_ENV=development 