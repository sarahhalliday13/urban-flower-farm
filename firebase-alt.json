{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "database": {
    "rules": "database.rules.json"
  },
  "emulators": {
    "functions": {
      "port": 5011
    },
    "database": {
      "port": 9011
    },
    "ui": {
      "enabled": true,
      "port": 4014
    },
    "hub": {
      "port": 4410
    },
    "logging": {
      "port": 4510
    }
  }
}
